{
  "mcpServers": {
    "patrol": {
      "command": "./.claude/run-patrol",
      "env": {
        "PROJECT_ROOT": "audio_player/example",
        "PATROL_FLAGS": "",
        "SHOW_TERMINAL": "false"
      }
    },
    "maestro": {
      "command": "maestro",
      "args": ["mcp"]
    },
    "dart": {
      "command": "/opt/homebrew/bin/fvm",
      "args": [
        "dart", "mcp-server"
      ]
    }
  }
}
